<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/month_navigation_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="@dimen/calendar_navigation_top_padding"
    android:paddingBottom="@dimen/calendar_navigation_bottom_padding">

    <com.google.android.material.button.MaterialButton
        style="?attr/navigationButtonStyle"
        android:id="@+id/month_navigation_previous"
        android:layout_width="@dimen/min_touch_target_size"
        android:layout_height="@dimen/calendar_navigation_height"
        app:icon="@drawable/ic_arrow_left"
        android:insetBottom="0dp"
        android:insetTop="0dp"/>

    <com.google.android.material.button.MaterialButton
        style="?attr/navigationButtonStyle"
        android:id="@+id/month_navigation_next"
        android:layout_width="@dimen/min_touch_target_size"
        android:layout_height="@dimen/calendar_navigation_height"
        app:icon="@drawable/ic_arrow_right"
        android:insetBottom="0dp"
        android:insetTop="0dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="right"
        tools:ignore="RtlHardcoded">

        <com.google.android.material.button.MaterialButton
            style="?attr/navigationToggleStyle"
            android:id="@+id/month_navigation_fragment_toggle"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/calendar_navigation_height"
            android:gravity="right|center_vertical"
            android:paddingEnd="@dimen/calendar_content_padding"
            android:paddingRight="@dimen/calendar_content_padding"
            android:singleLine="true"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            app:iconPadding="4dp"
            app:iconGravity="textStart"
            app:icon="@drawable/ic_menu_arrow_down"
            tools:ignore="RtlHardcoded,RtlSymmetry" />
    </LinearLayout>
</LinearLayout>
